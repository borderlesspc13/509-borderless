crosoft.com/office/word/2010/wordprocessingGroup" xmlns:wpi="http://schemas.microsoft.com/office/word/2010/wordprocessingInk" xmlns:wne="http://schemas.microsoft.com/office/word/2006/wordml" xmlns:wps="http://schemas.microsoft.com/office/word/2010/wordprocessingShape" mc:Ignorable="w14 w15 w16se w16cid w16 w16cex w16sdtdh wp14"><w:body><w:p w14:paraId="214564D4" w14:textId="1C8BDA1D" w:rsidR="00C73EEA" w:rsidRPr="000306CC" w:rsidRDefault="00D71146" w:rsidP="00D71146"><w:pPr><w:jc w:val="center"/><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:b/><w:bCs/><w:sz w:val="28"/><w:szCs w:val="28"/></w:rPr></w:pPr><w:r w:rsidRPr="000306CC"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:b/><w:bCs/><w:sz w:val="28"/><w:szCs w:val="28"/></w:rPr><w:t>Sistema Nurse Care</w:t></w:r></w:p><w:p w14:paraId="08624A2F" w14:textId="77777777" w:rsidR="007342A0" w:rsidRPr="00A124E4" w:rsidRDefault="007342A0" w:rsidP="007342A0"><w:pPr><w:pStyle w:val="NormalWeb"/><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/></w:rPr></w:pPr><w:r w:rsidRPr="00A124E4"><w:rPr><w:rStyle w:val="Strong"/><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/></w:rPr><w:t>Solicitação de Desenvolvimento – Módulo de Representação Gráfica de Lesões</w:t></w:r></w:p><w:p w14:paraId="3DC4978F" w14:textId="119556FC" w:rsidR="007342A0" w:rsidRPr="00A124E4" w:rsidRDefault="007342A0" w:rsidP="007342A0"><w:pPr><w:pStyle w:val="NormalWeb"/><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/></w:rPr></w:pPr><w:r w:rsidRPr="00A124E4"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/></w:rPr><w:t>Uma funcionalidade que permita a visualização anatômica em modelo tridimensional do corpo humano, com o objetivo de registrar e demonstrar graficamente as regiões acometidas por lesões dos aprendizes atendidos.</w:t></w:r></w:p><w:p w14:paraId="39F7226A" w14:textId="77777777" w:rsidR="007342A0" w:rsidRPr="00A124E4" w:rsidRDefault="007342A0" w:rsidP="007342A0"><w:pPr><w:pStyle w:val="NormalWeb"/><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/></w:rPr></w:pPr><w:r w:rsidRPr="00A124E4"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/></w:rPr><w:t>A funcionalidade deverá disponibilizar um modelo anatômico 3D (masculino e feminino), permitindo ao profissional selecionar a região do corpo correspondente à lesão. Após a seleção, a área deverá ser destacada em vermelho, facilitando a identificação visual da localização da lesão.</w:t></w:r></w:p><w:p w14:paraId="58F011B3" w14:textId="77777777" w:rsidR="007342A0" w:rsidRPr="00A124E4" w:rsidRDefault="007342A0" w:rsidP="007342A0"><w:pPr><w:pStyle w:val="NormalWeb"/><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/></w:rPr></w:pPr><w:r w:rsidRPr="00A124E4"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/></w:rPr><w:t>Além da marcação da região, o sistema deverá permitir:</w:t></w:r></w:p><w:p w14:paraId="0CE3EE07" w14:textId="77777777" w:rsidR="007342A0" w:rsidRPr="00A124E4" w:rsidRDefault="007342A0" w:rsidP="007342A0"><w:pPr><w:pStyle w:val="NormalWeb"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/></w:rPr></w:pPr><w:r w:rsidRPr="00A124E4"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/></w:rPr><w:t>Inserção de descrição da lesão;</w:t></w:r></w:p><w:p w14:paraId="1F2F2889" w14:textId="77777777" w:rsidR="007342A0" w:rsidRPr="00A124E4" w:rsidRDefault="007342A0" w:rsidP="007342A0"><w:pPr><w:pStyle w:val="NormalWeb"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/></w:rPr></w:pPr><w:r w:rsidRPr="00A124E4"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/></w:rPr><w:t>Identificação do lado acometido (direito, esquerdo ou bilateral);</w:t></w:r></w:p><w:p w14:paraId="6F32C6C4" w14:textId="77777777" w:rsidR="007342A0" w:rsidRPr="00A124E4" w:rsidRDefault="007342A0" w:rsidP="007342A0"><w:pPr><w:pStyle w:val="NormalWeb"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/></w:rPr></w:pPr><w:r w:rsidRPr="00A124E4"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/></w:rPr><w:t>Registro de observações e cuidados específicos relacionados à região lesionada;</w:t></w:r></w:p><w:p w14:paraId="0A00337C" w14:textId="77777777" w:rsidR="007342A0" w:rsidRPr="00A124E4" w:rsidRDefault="007342A0" w:rsidP="007342A0"><w:pPr><w:pStyle w:val="NormalWeb"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/></w:rPr></w:pPr><w:r w:rsidRPr="00A124E4"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/></w:rPr><w:t>Associação da imagem ao prontuário do aprendiz, para consulta e atualização sempre que necessário.</w:t></w:r></w:p><w:p w14:paraId="44C3CD46" w14:textId="77777777" w:rsidR="007342A0" w:rsidRPr="00A124E4" w:rsidRDefault="007342A0" w:rsidP="007342A0"><w:pPr><w:pStyle w:val="NormalWeb"/><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/></w:rPr></w:pPr><w:r w:rsidRPr="00A124E4"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/></w:rPr><w:t>A visualização deverá ter como finalidade facilitar a comunicação entre os profissionais da equipe multidisciplinar, permitindo rápida identificação das áreas que necessitam de maior cuidado durante os atendimentos, manuseios e intervenções terapêuticas.</w:t></w:r></w:p><w:p w14:paraId="26A6DD3C" w14:textId="77777777" w:rsidR="007342A0" w:rsidRPr="00A124E4" w:rsidRDefault="007342A0" w:rsidP="007342A0"><w:pPr><w:pStyle w:val="NormalWeb"/><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/></w:rPr></w:pPr><w:r w:rsidRPr="00A124E4"><w:rPr><w:rStyle w:val="Strong"/><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/></w:rPr><w:t>Exemplo de utilização:</w:t></w:r></w:p><w:p w14:paraId="6A82025D" w14:textId="77777777" w:rsidR="007342A0" w:rsidRPr="00A124E4" w:rsidRDefault="007342A0" w:rsidP="007342A0"><w:pPr><w:pStyle w:val="NormalWeb"/><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/></w:rPr></w:pPr><w:r w:rsidRPr="00A124E4"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/></w:rPr><w:t>O aprendiz apresenta uma lesão na mão direita e no antebraço direito. O profissional selecionará essas regiões no modelo anatômico, que serão automaticamente destacadas em vermelho. Abaixo da imagem, será possível registrar informações como: tipo da lesão, data de início, restrições, cuidados durante o atendimento e demais observações relevantes.</w:t></w:r></w:p><w:p w14:paraId="18A19323" w14:textId="77777777" w:rsidR="007342A0" w:rsidRPr="00A124E4" w:rsidRDefault="007342A0" w:rsidP="007342A0"><w:pPr><w:pStyle w:val="NormalWeb"/><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/></w:rPr></w:pPr><w:r w:rsidRPr="00A124E4"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/></w:rPr><w:t>O objetivo da funcionalidade é tornar a identificação das lesões mais intuitiva, padronizada e de fácil compreensão para todos os profissionais que acessam o prontuário do aprendiz.</w:t></w:r></w:p><w:p w14:paraId="3C3B552A" w14:textId="536943FE" w:rsidR="00D71146" w:rsidRPr="00A124E4" w:rsidRDefault="00D71146" w:rsidP="00D71146"><w:pPr><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/></w:rPr></w:pPr><w:r w:rsidRPr="00A124E4"><w:rPr><w:rFonts w:ascii="Arial" w:hAnsi="Arial" w:cs="Arial"/><w:b/><w:bCs/><w:noProof/></w:rPr><w:lastRenderedPageBreak/><w:drawing><wp:inline distT="0" distB="0" distL="0" distR="0" wp14:anchorId="1B27A25F" wp14:editId="30645B59"><wp:extent cx="4070555" cy="4070555"/><wp:effectExtent l="0" t="0" r="6350" b="6350"/><wp:docPr id="1" name="Picture 1"/><wp:cNvGraphicFramePr><a:graphicFrameLocks xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" noChangeAspect="1"/></wp:cNvGraphicFramePr><a:graphic xmlns:a