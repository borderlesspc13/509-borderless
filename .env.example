# =============================================================================
# 509 Borderless — variáveis de ambiente
# Copie para .env.local e preencha os valores:
#   cp .env.example .env.local
# =============================================================================

# --- Supabase (obrigatório) --------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# Use uma das duas chaves públicas (anon ou publishable):
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...

# Chave de serviço — apenas servidor (nunca exponha no client)
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---------------------------------------------------------------------
# URL pública do app (auth redirects). Em produção, use o domínio real.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- OpenAI / IA (opcional) --------------------------------------------------
# Sem OPENAI_API_KEY, o app entra em modo mock automaticamente.
OPENAI_API_KEY=
AI_DEFAULT_MODEL=gpt-4.1-mini
AI_GLOBAL_MODEL=gpt-4.1
# true | false — force mock mesmo com key, ou force API
# AI_MOCK_MODE=true

# --- Pagamentos (opcional) ---------------------------------------------------
# stripe (padrão) | mercado_pago
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=
# MERCADO_PAGO_ACCESS_TOKEN=
DEFAULT_SESSION_AMOUNT=150

# --- WhatsApp webhook (futuro / comentado no código) -------------------------
# WHATSAPP_WEBHOOK_TOKEN=
